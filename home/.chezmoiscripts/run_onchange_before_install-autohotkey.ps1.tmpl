{{ if eq .chezmoi.os "windows" -}}
# Ensures AutoHotkey is installed before dotfiles/scripts that depend on it run.

$ErrorActionPreference = "Stop"

function Test-CommandExists {
    param($Command)
    $null = Get-Command $Command -ErrorAction SilentlyContinue
    return $?
}

if (Test-CommandExists "winget") {
    $installed = winget list --id AutoHotkey.AutoHotkey --exact 2>$null
    if ($LASTEXITCODE -ne 0 -or -not ($installed -match "AutoHotkey")) {
        Write-Host "Installing AutoHotkey via winget..."
        winget install --id AutoHotkey.AutoHotkey --exact --silent --accept-package-agreements --accept-source-agreements
    } else {
        Write-Host "AutoHotkey already installed, skipping."
    }
} else {
    Write-Warning "winget not found. Install AutoHotkey manually from https://www.autohotkey.com/"
}
{{ end -}}
